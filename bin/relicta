#!/bin/bash
#
# relicta — curated laptop backup to S3-compatible storage, powered by restic.
#
#   https://github.com/swarajban/relicta
#
# One auditable file. Read it before you trust it — that's the point.
#
# Compatible with the bash 3.2 that ships with macOS. No dependencies beyond
# restic (and the macOS `security` CLI for Keychain access).

set -euo pipefail

RELICTA_VERSION="0.1.0"

# launchd agents start with a bare PATH (/usr/bin:/bin:/usr/sbin:/sbin);
# make Homebrew and user-local binaries visible.
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

CONFIG_DIR="${RELICTA_CONFIG_DIR:-$HOME/.config/relicta}"
STATE_DIR="${RELICTA_STATE_DIR:-$HOME/.local/state/relicta}"
LOG_DIR="${RELICTA_LOG_DIR:-$HOME/Library/Logs/relicta}"

CONFIG_FILE="$CONFIG_DIR/config"
INCLUDES_FILE="$CONFIG_DIR/includes.txt"
EXCLUDES_FILE="$CONFIG_DIR/excludes.txt"
MANIFEST_DIR="$CONFIG_DIR/manifests"
LOCK_DIR="$STATE_DIR/lock.d"
PLIST_LABEL="com.relicta.backup"

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------

log() { printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"; }

die() {
  log "ERROR: $*" >&2
  exit 1
}

# Best-effort macOS notification; never fails the run. Message must not
# contain double quotes.
notify() {
  command -v osascript >/dev/null 2>&1 || return 0
  osascript -e "display notification \"$1\" with title \"relicta\"" >/dev/null 2>&1 || true
}

load_config() {
  [ -f "$CONFIG_FILE" ] || die "no config at $CONFIG_FILE — run install.sh (or relicta init) first"
  # shellcheck source=/dev/null
  . "$CONFIG_FILE"
  : "${RELICTA_REPOSITORY:?RELICTA_REPOSITORY not set in $CONFIG_FILE}"
  : "${RELICTA_HOST:?RELICTA_HOST not set in $CONFIG_FILE}"
  RELICTA_S3_REGION="${RELICTA_S3_REGION:-auto}"
  RELICTA_KEEP_DAILY="${RELICTA_KEEP_DAILY:-7}"
  RELICTA_KEEP_WEEKLY="${RELICTA_KEEP_WEEKLY:-4}"
  RELICTA_KEEP_MONTHLY="${RELICTA_KEEP_MONTHLY:-6}"
  RELICTA_PRUNE_EVERY_DAYS="${RELICTA_PRUNE_EVERY_DAYS:-7}"
  RELICTA_CHECK_READ_SUBSET="${RELICTA_CHECK_READ_SUBSET:-5%}"
  RELICTA_KEYCHAIN_PREFIX="${RELICTA_KEYCHAIN_PREFIX:-relicta}"
  RELICTA_SKIP_ON_BATTERY="${RELICTA_SKIP_ON_BATTERY:-false}"
  RELICTA_MANIFESTS="${RELICTA_MANIFESTS:-true}"
  RELICTA_EXTRA_BACKUP_ARGS="${RELICTA_EXTRA_BACKUP_ARGS:-}"
}

secret_get() {
  /usr/bin/security find-generic-password -a "$USER" -s "$1" -w 2>/dev/null
}

# Exports RESTIC_* and (for s3: repos) AWS_* credentials into the
# environment. Secrets live in the macOS Keychain and are only ever held
# in memory here — never written to disk. Setting RESTIC_PASSWORD (and, if
# needed, AWS_ACCESS_KEY_ID) in the environment bypasses the Keychain,
# which is how CI and the smoke test run.
export_secrets() {
  export RESTIC_REPOSITORY="$RELICTA_REPOSITORY"
  if [ -z "${RESTIC_PASSWORD:-}" ] && [ -z "${RESTIC_PASSWORD_COMMAND:-}" ]; then
    export RESTIC_PASSWORD_COMMAND="/usr/bin/security find-generic-password -s ${RELICTA_KEYCHAIN_PREFIX}.restic-password -a $USER -w"
  fi
  case "$RELICTA_REPOSITORY" in
    s3:*)
      if [ -z "${AWS_ACCESS_KEY_ID:-}" ]; then
        local key_id secret
        key_id="$(secret_get "${RELICTA_KEYCHAIN_PREFIX}.s3-key-id" || true)"
        secret="$(secret_get "${RELICTA_KEYCHAIN_PREFIX}.s3-secret" || true)"
        if [ -n "$key_id" ] && [ -n "$secret" ]; then
          export AWS_ACCESS_KEY_ID="$key_id"
          export AWS_SECRET_ACCESS_KEY="$secret"
        fi
        # Otherwise fall through to ambient credentials (~/.aws, env).
      fi
      export AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-$RELICTA_S3_REGION}"
      ;;
  esac
}

# stdin -> stdout: drop comment/blank lines, expand a leading ~/ to $HOME/.
# restic does NOT expand ~ itself in --files-from / --exclude-file entries.
expand_pathfile() {
  sed -e '/^[[:space:]]*#/d' -e '/^[[:space:]]*$/d' -e "s|^~/|$HOME/|"
}

# macOS has no flock(1); an atomic mkdir is the portable lock. The EXIT trap
# also fires a notification if a backup run dies unexpectedly.
acquire_lock() {
  mkdir -p "$STATE_DIR"
  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    local pid
    pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || echo "")"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      log "another backup is running (pid $pid); exiting"
      exit 0
    fi
    log "removing stale lock (pid ${pid:-unknown})"
    rm -rf "$LOCK_DIR"
    mkdir "$LOCK_DIR" || die "could not acquire lock at $LOCK_DIR"
  fi
  echo $$ >"$LOCK_DIR/pid"
  trap on_backup_exit EXIT
}

on_backup_exit() {
  local rc=$?
  rm -rf "$LOCK_DIR"
  if [ "$rc" -ne 0 ] && [ "$rc" -ne 3 ]; then
    notify "Backup failed (exit $rc). See ~/Library/Logs/relicta"
  fi
}

# ---------------------------------------------------------------------------
# manifests — capture the re-installable world as text so the backup set can
# stay small. Every dump is best-effort: a missing tool never aborts a backup.
# ---------------------------------------------------------------------------

dump_manifests() {
  [ "$RELICTA_MANIFESTS" = "true" ] || return 0
  mkdir -p "$MANIFEST_DIR"
  log "dumping manifests to $MANIFEST_DIR"
  if command -v brew >/dev/null 2>&1; then
    brew bundle dump --force --file="$MANIFEST_DIR/Brewfile" >/dev/null 2>&1 || log "warn: brew bundle dump failed"
  fi
  if command -v code >/dev/null 2>&1; then
    code --list-extensions >"$MANIFEST_DIR/vscode-extensions.txt" 2>/dev/null || true
  fi
  if command -v cursor >/dev/null 2>&1; then
    cursor --list-extensions >"$MANIFEST_DIR/cursor-extensions.txt" 2>/dev/null || true
  fi
  if [ -f "$HOME/.antigravity/extensions/extensions.json" ]; then
    cp "$HOME/.antigravity/extensions/extensions.json" "$MANIFEST_DIR/antigravity-extensions.json" 2>/dev/null || true
  fi
  if [ -d "$HOME/.local/bin" ]; then
    ls -la "$HOME/.local/bin" >"$MANIFEST_DIR/local-bin.txt" 2>/dev/null || true
  fi
  if command -v mise >/dev/null 2>&1; then
    mise ls >"$MANIFEST_DIR/mise.txt" 2>/dev/null || true
  fi
  if command -v npm >/dev/null 2>&1; then
    npm ls -g --depth=0 >"$MANIFEST_DIR/npm-globals.txt" 2>/dev/null || true
  fi
  crontab -l >"$MANIFEST_DIR/crontab.txt" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# maintenance — `forget` is cheap metadata and runs every backup; `prune`
# repacks data (expensive in time and S3 ops) and `check` re-reads a rotating
# subset, so both run on a stamp-file cadence rather than a weekday (a laptop
# that sleeps every Sunday would otherwise never prune).
# ---------------------------------------------------------------------------

maybe_prune_and_check() {
  local last now age_days
  last="$(cat "$STATE_DIR/last-prune" 2>/dev/null || echo 0)"
  now="$(date +%s)"
  age_days=$(((now - last) / 86400))
  if [ "$age_days" -lt "$RELICTA_PRUNE_EVERY_DAYS" ]; then
    return 0
  fi
  log "maintenance: prune + check (last ran ${age_days}d ago)"
  restic unlock # clears stale locks only; safe
  restic forget --host "$RELICTA_HOST" \
    --keep-daily "$RELICTA_KEEP_DAILY" \
    --keep-weekly "$RELICTA_KEEP_WEEKLY" \
    --keep-monthly "$RELICTA_KEEP_MONTHLY" \
    --prune
  restic check --read-data-subset="$RELICTA_CHECK_READ_SUBSET"
  restic cache --cleanup >/dev/null 2>&1 || true
  date +%s >"$STATE_DIR/last-prune"
}

# ---------------------------------------------------------------------------
# backup
# ---------------------------------------------------------------------------

cmd_backup() {
  local scheduled=false tag="manual"
  if [ "${1:-}" = "--scheduled" ]; then
    scheduled=true
    tag="scheduled"
  fi

  load_config
  mkdir -p "$STATE_DIR" "$LOG_DIR"

  # Freshness guard: launchd fires this several times a day (two calendar
  # slots plus RunAtLoad); this collapses them to at most ~one real
  # backup per day, and makes login-after-days-off catch up immediately.
  if [ "$scheduled" = "true" ] && [ -f "$STATE_DIR/last-success" ]; then
    local last now age
    last="$(cat "$STATE_DIR/last-success" 2>/dev/null || echo 0)"
    now="$(date +%s)"
    age=$((now - last))
    if [ "$age" -lt $((20 * 3600)) ]; then
      log "skip: last successful backup $((age / 3600))h ago (< 20h)"
      return 0
    fi
  fi

  if [ "$RELICTA_SKIP_ON_BATTERY" = "true" ] && command -v pmset >/dev/null 2>&1; then
    if ! pmset -g batt 2>/dev/null | grep -q 'AC Power'; then
      log "skip: on battery (RELICTA_SKIP_ON_BATTERY=true)"
      return 0
    fi
  fi

  [ -f "$INCLUDES_FILE" ] || die "no includes file at $INCLUDES_FILE"

  acquire_lock

  # Mirror all output into a per-run log file. The launchd plist's own
  # StandardOutPath only catches errors that happen before this line.
  local logfile
  logfile="$LOG_DIR/backup-$(date +%Y%m%d-%H%M%S).log"
  exec > >(tee -a "$logfile") 2>&1

  log "relicta $RELICTA_VERSION — backup starting (tag: $tag)"
  log "repository: $RELICTA_REPOSITORY (host: $RELICTA_HOST)"

  export_secrets
  dump_manifests

  local tmp_inc tmp_exc
  tmp_inc="$(mktemp)"
  tmp_exc="$(mktemp)"
  expand_pathfile <"$INCLUDES_FILE" >"$tmp_inc"
  if [ -f "$EXCLUDES_FILE" ]; then
    expand_pathfile <"$EXCLUDES_FILE" >"$tmp_exc"
  fi

  # Fewer, larger connections for object storage; harmless to omit elsewhere.
  local s3_opts=""
  case "$RELICTA_REPOSITORY" in
    s3:*) s3_opts="-o s3.connections=8" ;;
  esac

  local rc=0
  set +e
  # shellcheck disable=SC2086  # s3_opts and EXTRA args are intentionally word-split
  restic backup \
    --files-from "$tmp_inc" \
    --exclude-file "$tmp_exc" \
    --exclude-caches \
    --host "$RELICTA_HOST" \
    --tag "$tag" \
    --retry-lock 10m \
    $s3_opts \
    $RELICTA_EXTRA_BACKUP_ARGS
  rc=$?
  set -e
  rm -f "$tmp_inc" "$tmp_exc"

  case "$rc" in
    0)
      log "backup ok"
      ;;
    3)
      # restic exit 3: a snapshot WAS created, but some source files were
      # unreadable. On macOS this is almost always a missing/revoked Full
      # Disk Access grant on the restic binary (TCC) — reads of ~/Desktop,
      # ~/Documents etc. fail silently with EPERM under launchd.
      log "backup PARTIAL: some files could not be read (restic exit 3)"
      notify "Backup PARTIAL: some files unreadable — likely Full Disk Access. Run: relicta doctor"
      ;;
    *)
      die "backup failed (restic exit $rc)"
      ;;
  esac

  log "applying retention: ${RELICTA_KEEP_DAILY}d / ${RELICTA_KEEP_WEEKLY}w / ${RELICTA_KEEP_MONTHLY}m"
  restic forget --host "$RELICTA_HOST" \
    --keep-daily "$RELICTA_KEEP_DAILY" \
    --keep-weekly "$RELICTA_KEEP_WEEKLY" \
    --keep-monthly "$RELICTA_KEEP_MONTHLY" >/dev/null

  maybe_prune_and_check

  # PARTIAL still stamps success: a snapshot exists, and the notification
  # has already told the user to fix Full Disk Access.
  date +%s >"$STATE_DIR/last-success"
  find "$LOG_DIR" -name 'backup-*.log' -mtime +30 -delete 2>/dev/null || true
  # Keep the launchd side-channel log from growing unbounded.
  if [ -f "$LOG_DIR/launchd.log" ] && [ "$(stat -f%z "$LOG_DIR/launchd.log" 2>/dev/null || echo 0)" -gt 5242880 ]; then
    : >"$LOG_DIR/launchd.log"
  fi
  log "done"
}

# ---------------------------------------------------------------------------
# doctor — diagnose the unattended path
# ---------------------------------------------------------------------------

doctor_report() {
  # $1 = ok|warn|fail, $2 = message
  case "$1" in
    ok) printf '  [ok]   %s\n' "$2" ;;
    warn) printf '  [warn] %s\n' "$2" ;;
    fail)
      printf '  [FAIL] %s\n' "$2"
      DOCTOR_FAILED=true
      ;;
  esac
}

cmd_doctor() {
  load_config
  DOCTOR_FAILED=false
  echo "relicta doctor"

  if command -v restic >/dev/null 2>&1; then
    doctor_report ok "restic: $(restic version 2>/dev/null | head -1)"
  else
    doctor_report fail "restic not found on PATH — brew install restic"
  fi

  if [ -n "${RESTIC_PASSWORD:-}" ]; then
    doctor_report ok "repo password: from RESTIC_PASSWORD env"
  elif secret_get "${RELICTA_KEYCHAIN_PREFIX}.restic-password" >/dev/null; then
    doctor_report ok "repo password: readable from Keychain"
  else
    doctor_report fail "repo password: Keychain item ${RELICTA_KEYCHAIN_PREFIX}.restic-password unreadable (locked keychain? never initialized?)"
  fi

  export_secrets
  if restic cat config >/dev/null 2>&1; then
    doctor_report ok "repository reachable: $RELICTA_REPOSITORY"
  else
    doctor_report fail "repository NOT reachable: $RELICTA_REPOSITORY (credentials? network? corporate TLS interception?)"
  fi

  if launchctl print "gui/$(id -u)/$PLIST_LABEL" >/dev/null 2>&1; then
    doctor_report ok "launchd agent loaded: $PLIST_LABEL"
  else
    doctor_report warn "launchd agent not loaded — scheduled backups are OFF (run install.sh)"
  fi

  if [ -f "$STATE_DIR/last-success" ]; then
    local last now age_h
    last="$(cat "$STATE_DIR/last-success")"
    now="$(date +%s)"
    age_h=$(((now - last) / 3600))
    if [ "$age_h" -lt 48 ]; then
      doctor_report ok "last successful backup: ${age_h}h ago"
    else
      doctor_report warn "last successful backup: ${age_h}h ago (> 48h)"
    fi
  else
    doctor_report warn "no successful backup recorded yet"
  fi

  # TCC detection: permission-denied reads in the most recent log almost
  # always mean the restic binary lost its Full Disk Access grant
  # (brew upgrade replaces the binary and silently invalidates the grant).
  local latest_log denied
  # shellcheck disable=SC2012  # log names are our own timestamped pattern
  latest_log="$(ls -t "$LOG_DIR"/backup-*.log 2>/dev/null | head -1 || true)"
  if [ -n "$latest_log" ]; then
    denied="$(grep -ci 'permission denied' "$latest_log" 2>/dev/null || true)"
    if [ -n "$denied" ] && [ "$denied" -gt 0 ]; then
      doctor_report fail "latest run had $denied permission-denied reads — re-grant Full Disk Access to restic (see docs/FULL-DISK-ACCESS.md), required again after every 'brew upgrade restic'"
    else
      doctor_report ok "no permission-denied reads in latest run"
    fi
  fi

  if [ "$DOCTOR_FAILED" = "true" ]; then
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# restore-test — prove the snapshot actually contains what the disk has
# ---------------------------------------------------------------------------

cmd_restore_test() {
  load_config
  export_secrets
  local probe="${1:-$HOME/.gitconfig}"
  [ -f "$probe" ] || die "probe file $probe does not exist locally (pass a path: relicta restore-test <file>)"
  log "comparing latest snapshot copy of $probe against local file"
  if restic dump latest "$probe" 2>/dev/null | cmp -s - "$probe"; then
    log "restore-test OK: snapshot copy of $probe matches the local file"
  else
    die "restore-test FAILED: snapshot copy of $probe is missing or differs (has the file changed since the last backup?)"
  fi
}

# ---------------------------------------------------------------------------
# init — interactive first-time setup (called by install.sh)
# ---------------------------------------------------------------------------

cmd_init() {
  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR"

  if [ -f "$CONFIG_FILE" ]; then
    echo "Config already exists at $CONFIG_FILE — re-running init will overwrite it."
    printf 'Continue? [y/N] '
    read -r answer
    case "$answer" in y | Y | yes) ;; *) die "aborted" ;; esac
  fi

  echo "Where should backups go?"
  echo "  1) AWS S3"
  echo "  2) Cloudflare R2"
  echo "  3) Backblaze B2 (S3-compatible endpoint)"
  echo "  4) Other S3-compatible / full restic URL"
  printf 'Choice [1-4]: '
  read -r backend

  local repo_url="" region="auto"
  local bucket prefix account endpoint
  case "$backend" in
    1)
      printf 'AWS region (e.g. us-west-2): '
      read -r region
      printf 'Bucket name: '
      read -r bucket
      printf 'Prefix (one per machine, e.g. yourname-mbp): '
      read -r prefix
      repo_url="s3:s3.${region}.amazonaws.com/${bucket}/${prefix}"
      ;;
    2)
      printf 'Cloudflare account ID: '
      read -r account
      printf 'Bucket name: '
      read -r bucket
      printf 'Prefix (one per machine, e.g. yourname-mbp): '
      read -r prefix
      repo_url="s3:https://${account}.r2.cloudflarestorage.com/${bucket}/${prefix}"
      region="auto"
      ;;
    3)
      printf 'B2 S3 endpoint (e.g. s3.us-west-004.backblazeb2.com): '
      read -r endpoint
      printf 'Bucket name: '
      read -r bucket
      printf 'Prefix (one per machine, e.g. yourname-mbp): '
      read -r prefix
      repo_url="s3:https://${endpoint}/${bucket}/${prefix}"
      region="auto"
      ;;
    4)
      printf 'Full restic repository URL (e.g. s3:https://host/bucket/prefix): '
      read -r repo_url
      printf 'Region (auto unless AWS): '
      read -r region
      ;;
    *) die "invalid choice" ;;
  esac

  local host_default host_id
  host_default="$(scutil --get LocalHostName 2>/dev/null | tr '[:upper:]' '[:lower:]' || hostname -s)"
  printf 'Machine ID for snapshots [%s]: ' "$host_default"
  read -r host_id
  host_id="${host_id:-$host_default}"

  local kc_prefix="relicta"

  echo
  echo "Storage credentials (an access key scoped to this bucket/prefix):"
  printf 'Access key ID: '
  read -r s3_key_id
  printf 'Secret access key (hidden): '
  read -rs s3_secret
  echo

  echo
  echo "The restic repository password encrypts every byte of your backup."
  printf 'Generate one for you? [Y/n] '
  read -r gen
  local restic_pw
  case "$gen" in
    n | N)
      printf 'Enter repository password (hidden): '
      read -rs restic_pw
      echo
      ;;
    *)
      restic_pw="$(openssl rand -base64 32)"
      echo
      echo "  Your repository password is:"
      echo
      echo "      $restic_pw"
      echo
      ;;
  esac

  echo "==========================================================================="
  echo "  STOP. Put this password in 1Password (or your team's vault) RIGHT NOW."
  echo "  The Keychain copy dies with this laptop. Without the password, the"
  echo "  backup is cryptographically worthless — nobody can recover it. Ever."
  echo "==========================================================================="
  local ack=""
  while [ "$ack" != "stored" ]; do
    printf 'Type "stored" once the password is escrowed: '
    read -r ack
  done

  # -T /usr/bin/security pre-authorizes the security binary on the item ACL
  # so unattended launchd runs never pop a Keychain permission dialog.
  /usr/bin/security add-generic-password -U -a "$USER" -s "${kc_prefix}.restic-password" -T /usr/bin/security -w "$restic_pw"
  /usr/bin/security add-generic-password -U -a "$USER" -s "${kc_prefix}.s3-key-id" -T /usr/bin/security -w "$s3_key_id"
  /usr/bin/security add-generic-password -U -a "$USER" -s "${kc_prefix}.s3-secret" -T /usr/bin/security -w "$s3_secret"
  echo "Credentials stored in the macOS Keychain (${kc_prefix}.*)."

  cat >"$CONFIG_FILE" <<EOF
# relicta configuration — sourced as shell. Keep owner-only permissions.
RELICTA_REPOSITORY="$repo_url"
RELICTA_S3_REGION="$region"
RELICTA_HOST="$host_id"

RELICTA_KEEP_DAILY=7
RELICTA_KEEP_WEEKLY=4
RELICTA_KEEP_MONTHLY=6
RELICTA_PRUNE_EVERY_DAYS=7
RELICTA_CHECK_READ_SUBSET="5%"

RELICTA_KEYCHAIN_PREFIX="$kc_prefix"
RELICTA_SKIP_ON_BATTERY=false
RELICTA_MANIFESTS=true
RELICTA_EXTRA_BACKUP_ARGS=""
EOF
  chmod 600 "$CONFIG_FILE"
  echo "Wrote $CONFIG_FILE"

  load_config
  export_secrets
  if restic cat config >/dev/null 2>&1; then
    echo "Existing restic repository found — reusing it."
  else
    echo "Initializing restic repository at $repo_url ..."
    restic init
  fi
  echo "Init complete. Edit $INCLUDES_FILE to curate what gets backed up."
}

# ---------------------------------------------------------------------------
# small passthroughs
# ---------------------------------------------------------------------------

cmd_run() {
  load_config
  export_secrets
  exec restic "$@"
}

usage() {
  cat <<EOF
relicta $RELICTA_VERSION — curated laptop backup to S3-compatible storage via restic

usage: relicta <command> [args]

  backup [--scheduled]   run a backup (--scheduled respects the 20h freshness guard)
  init                   interactive setup: backend, credentials -> Keychain, restic init
  doctor                 diagnose the unattended path (keychain, repo, launchd, TCC)
  snapshots [...]        list snapshots
  restore-test [file]    verify a file in the latest snapshot matches the local copy
  prune                  run retention + prune + integrity check now
  check [...]            restic check
  unlock                 clear stale repository locks
  run <restic args...>   run any restic command with relicta's env (e.g. relicta run stats)
  version                print version

config: $CONFIG_DIR   state: $STATE_DIR   logs: $LOG_DIR
EOF
}

main() {
  local cmd="${1:-help}"
  if [ $# -gt 0 ]; then shift; fi
  case "$cmd" in
    backup) cmd_backup "$@" ;;
    init) cmd_init "$@" ;;
    doctor) cmd_doctor "$@" ;;
    snapshots)
      load_config
      export_secrets
      exec restic snapshots "$@"
      ;;
    restore-test) cmd_restore_test "$@" ;;
    prune)
      load_config
      export_secrets
      RELICTA_PRUNE_EVERY_DAYS=0
      mkdir -p "$STATE_DIR"
      maybe_prune_and_check
      ;;
    check)
      load_config
      export_secrets
      exec restic check "$@"
      ;;
    unlock)
      load_config
      export_secrets
      exec restic unlock
      ;;
    run) cmd_run "$@" ;;
    version) echo "relicta $RELICTA_VERSION" ;;
    help | -h | --help) usage ;;
    *)
      usage >&2
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
